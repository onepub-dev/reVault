prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: revault-api
Description: Stable native API for reVault lockboxes and vaults
Version: @PROJECT_VERSION@
Libs: -L${libdir} -lrevault_api
Cflags: -I${includedir}
