@PACKAGE_INIT@
include(CMakeFindDependencyMacro)
find_library(REVAULT_API_LIBRARY NAMES revault_api REQUIRED)
if(NOT TARGET revault-api::revault-api)
  add_library(revault-api::revault-api SHARED IMPORTED)
  set_target_properties(revault-api::revault-api PROPERTIES
    IMPORTED_LOCATION "${REVAULT_API_LIBRARY}"
    INTERFACE_INCLUDE_DIRECTORIES "${PACKAGE_PREFIX_DIR}/include")
endif()
check_required_components(revault-api)
